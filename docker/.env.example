# Docker Compose environment variable overrides
# Copy this to docker/.env to customize local settings
# Default values are shown (these work out of the box)

# PostgreSQL
POSTGRES_DB=smithy
POSTGRES_USER=smithy
POSTGRES_PASSWORD=smithy
POSTGRES_PORT=5432

# Redis
REDIS_PORT=6379

# RabbitMQ
RABBITMQ_USER=smithy
RABBITMQ_PASSWORD=smithy
RABBITMQ_PORT=5672
RABBITMQ_MGMT_PORT=15672

# MinIO
MINIO_ROOT_USER=smithy
MINIO_ROOT_PASSWORD=smithy_secret
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_BUCKET=smithy
