# =============================================================================
# Smithy AI — Environment Variable Template
# =============================================================================
# Copy this file to docker/.env to configure your local development environment.
# All defaults work out of the box with the Docker Compose stack.
# DO NOT commit real secrets to version control.
# =============================================================================

# === Application ===

# Port the NestJS API server listens on
APP_PORT=3000

# Node.js runtime environment (development | production | test)
NODE_ENV=development

# === Security ===

# Secret used to sign and verify JWT tokens. Change this in production!
JWT_SECRET=change-me-in-production-use-a-long-random-string

# Comma-separated list of allowed CORS origins for the API
CORS_ORIGIN=http://localhost:5173

# === Logging ===

# Application log level (error | warn | info | debug | verbose)
LOG_LEVEL=info

# === PostgreSQL ===

# Full PostgreSQL connection URL used by the API (Drizzle ORM)
DATABASE_URL=postgresql://smithy:smithy@localhost:5432/smithy

# Name of the PostgreSQL database (Docker Compose service var)
POSTGRES_DB=smithy

# PostgreSQL superuser username (Docker Compose service var)
POSTGRES_USER=smithy

# PostgreSQL superuser password (Docker Compose service var)
POSTGRES_PASSWORD=smithy

# Host port mapped to the PostgreSQL container (Docker Compose service var)
POSTGRES_PORT=5432

# === Redis ===

# Full Redis connection URL used by the API (caching, sessions, Socket.IO adapter)
REDIS_URL=redis://localhost:6379

# Host port mapped to the Redis container (Docker Compose service var)
REDIS_PORT=6379

# === RabbitMQ ===

# Full AMQP connection URL used by the API (message bus for worker jobs)
RABBITMQ_URL=amqp://smithy:smithy@localhost:5672

# RabbitMQ management UI — available at this URL after `docker compose up`
RABBITMQ_MANAGEMENT_URL=http://localhost:15672

# RabbitMQ default username (Docker Compose service var)
RABBITMQ_USER=smithy

# RabbitMQ default password (Docker Compose service var)
RABBITMQ_PASSWORD=smithy

# Host port mapped to the RabbitMQ AMQP port (Docker Compose service var)
RABBITMQ_PORT=5672

# Host port mapped to the RabbitMQ management UI (Docker Compose service var)
RABBITMQ_MGMT_PORT=15672

# === MinIO (S3-compatible object storage) ===

# MinIO API endpoint used by the API to upload/download package files
MINIO_ENDPOINT=http://localhost:9000

# Access key for MinIO authentication (maps to MINIO_ROOT_USER in development)
MINIO_ACCESS_KEY=smithy

# Secret key for MinIO authentication (maps to MINIO_ROOT_PASSWORD in development)
MINIO_SECRET_KEY=smithy_secret

# Default bucket for storing Smithy package files
MINIO_BUCKET=smithy

# MinIO web console — available at this URL after `docker compose up`
MINIO_CONSOLE_URL=http://localhost:9001

# MinIO root username (Docker Compose service var)
MINIO_ROOT_USER=smithy

# MinIO root password (Docker Compose service var)
MINIO_ROOT_PASSWORD=smithy_secret

# Host port mapped to the MinIO API (Docker Compose service var)
MINIO_PORT=9000

# Host port mapped to the MinIO web console (Docker Compose service var)
MINIO_CONSOLE_PORT=9001

# === AI Providers ===

# OpenAI API key — required for AI-powered workers that use GPT models.
# Get your key at https://platform.openai.com/account/api-keys
OPENAI_API_KEY=your-openai-api-key

# Anthropic API key — required for AI-powered workers that use Claude models.
# Get your key at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your-anthropic-api-key

# === Email (Resend) ===

# Resend API key for transactional email notifications.
# Optional for basic local development — workers that send emails will fail without it.
# Get your key at https://resend.com/api-keys
RESEND_API_KEY=your-resend-api-key
