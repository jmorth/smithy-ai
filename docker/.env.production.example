# =============================================================================
# Smithy AI — Production Environment Variables Template
# =============================================================================
# Copy this file to docker/.env and fill in ALL values before deploying.
# DO NOT commit real secrets to version control.
#
# Usage:
#   cp docker/.env.production.example docker/.env
#   # Edit docker/.env with your production values
#   docker compose -f docker/docker-compose.yml -f docker/docker-compose.prod.yml up -d
# =============================================================================

# === Application =============================================================

# Node.js runtime environment — must be "production" for production deployments
NODE_ENV=production

# Port the NestJS API server listens on (internal, not exposed to the host)
APP_PORT=3000

# === Security ================================================================

# Secret used to sign and verify JWT tokens. MUST be a long, random string.
# Generate with: openssl rand -base64 48
JWT_SECRET=CHANGE_ME_GENERATE_WITH_openssl_rand_base64_48

# Comma-separated list of allowed CORS origins for the API
CORS_ORIGIN=https://your-domain.com

# === Logging =================================================================

# Application log level (error | warn | info)
LOG_LEVEL=info

# === PostgreSQL ==============================================================

# Full PostgreSQL connection URL used by the API (Drizzle ORM)
# Format: postgresql://<user>:<password>@<host>:<port>/<database>
DATABASE_URL=postgresql://smithy:CHANGE_ME@postgres:5432/smithy

# PostgreSQL database name
POSTGRES_DB=smithy

# PostgreSQL username
POSTGRES_USER=smithy

# PostgreSQL password — use a strong, unique password in production
POSTGRES_PASSWORD=CHANGE_ME

# Host port mapped to the PostgreSQL container (optional, for external access)
POSTGRES_PORT=5432

# === Redis ===================================================================

# Full Redis connection URL used by the API (caching, sessions, Socket.IO adapter)
# Format: redis://:<password>@<host>:<port>
REDIS_URL=redis://:CHANGE_ME@redis:6379

# Redis authentication password — use a strong, unique password in production
REDIS_PASSWORD=CHANGE_ME

# Host port mapped to the Redis container (optional, for external access)
REDIS_PORT=6379

# === RabbitMQ ================================================================

# Full AMQP connection URL used by the API (message bus for worker jobs)
# Format: amqp://<user>:<password>@<host>:<port>
RABBITMQ_URL=amqp://smithy:CHANGE_ME@rabbitmq:5672

# RabbitMQ management UI URL (optional, for external access)
RABBITMQ_MANAGEMENT_URL=http://localhost:15672

# RabbitMQ default username
RABBITMQ_DEFAULT_USER=smithy

# RabbitMQ default password — use a strong, unique password in production
RABBITMQ_DEFAULT_PASS=CHANGE_ME

# Host port mapped to the RabbitMQ AMQP port (optional, for external access)
RABBITMQ_PORT=5672

# Host port mapped to the RabbitMQ management UI (optional, for external access)
RABBITMQ_MGMT_PORT=15672

# === MinIO (S3-compatible object storage) ====================================

# MinIO API endpoint used by the API to upload/download package files
MINIO_ENDPOINT=http://minio:9000

# Access key for MinIO authentication
MINIO_ACCESS_KEY=CHANGE_ME

# Secret key for MinIO authentication
MINIO_SECRET_KEY=CHANGE_ME

# Default bucket for storing Smithy package files
MINIO_BUCKET=smithy

# MinIO root username (Docker Compose service var)
MINIO_ROOT_USER=CHANGE_ME

# MinIO root password — use a strong, unique password in production
MINIO_ROOT_PASSWORD=CHANGE_ME

# Host port mapped to the MinIO API (optional, for external access)
MINIO_PORT=9000

# Host port mapped to the MinIO web console (optional, for external access)
MINIO_CONSOLE_PORT=9001

# === Nginx / Public Access ===================================================

# Public HTTPS port exposed by the Nginx reverse proxy
PUBLIC_PORT=443

# Public HTTP port exposed by the Nginx reverse proxy (redirects to HTTPS)
PUBLIC_HTTP_PORT=80

# === AI Providers ============================================================

# OpenAI API key — required for AI-powered workers that use GPT models
# Get your key at https://platform.openai.com/account/api-keys
OPENAI_API_KEY=sk-your-openai-api-key

# Anthropic API key — required for AI-powered workers that use Claude models
# Get your key at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key

# === Email (Resend) ==========================================================

# Resend API key for transactional email notifications
# Get your key at https://resend.com/api-keys
RESEND_API_KEY=re_your_resend_api_key

# Sender address for outbound notification emails
EMAIL_FROM=notifications@your-domain.com

# Dashboard base URL used to construct links in notification emails
DASHBOARD_URL=https://your-domain.com
