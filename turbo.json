{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["src/**", "!src/**/*.test.ts", "!src/**/*.spec.ts", "tsconfig*.json", "package.json"],
      "outputs": ["dist/**"]
    },
    "lint": {
      "dependsOn": ["^build"],
      "inputs": ["src/**", "*.js", "*.ts", ".eslintrc*", "eslint.config.*", "package.json"]
    },
    "test": {
      "dependsOn": ["^build"],
      "inputs": ["src/**", "test/**", "tsconfig*.json", "vitest.config.*", "jest.config.*", "package.json"]
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "inputs": ["src/**", "tsconfig*.json", "package.json"]
    },
    "dev": {
      "persistent": true,
      "cache": false
    }
  }
}
